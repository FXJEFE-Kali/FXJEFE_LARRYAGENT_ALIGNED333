#### 2. Replace your current `_create_new_skill` method with this refined version

```python
    def _create_new_skill(self, skill_name: str, description: str = None) -> str:
        """Refined auto skill creation with persistence, sanitization and rich template."""
        if not self.skill_manager:
            return "❌ Skill manager not available."

        # Sanitize and validate name
        clean_name = re.sub(r'[^a-z0-9_]', '_', skill_name.lower().strip())
        if not clean_name or clean_name in ["system_info", "code_review", "file_summary", "disk_usage", "port_check"]:
            return f"❌ Name '{clean_name}' is reserved or invalid."

        if self.skill_manager.get_skill(clean_name):
            return f"⚠️ Skill '{clean_name}' already exists. Use /skill {clean_name} to run it."

        if not description:
            description = f"User-created skill: {clean_name}"

        # Dynamic function with helpful template
        def dynamic_skill(**kwargs):
            args_str = ", ".join(f"{k}={v}" for k, v in kwargs.items()) if kwargs else "no args"
            return (f"✅ Skill '{clean_name}' activated!\n"
                    f"Description: {description}\n"
                    f"Args received: {args_str}\n"
                    f"Tip: Edit this skill in skill_manager.py or say 'edit skill {clean_name}'")

        self.skill_manager.register_skill(
            name=clean_name,
            description=description,
            category="user_created",
            function=dynamic_skill,
            examples=[f"/skill {clean_name}", f"run {clean_name}"],
            parameters={"args": "Any additional arguments"}
        )

        # Persist and log
        self._save_persistent_skills()
        self._log_improvement("create_skill", clean_name, f"Skill created: {description}")

        return (f"✅ **Skill '{clean_name}' created and saved permanently!**\n"
                f"Use it immediately with `/skill {clean_name}`\n"
                f"See all improvements with `/improvements`")
```

#### 3. Add these new methods (paste after `_create_new_skill`)

```python
    # ── PERSISTENT SKILL STORAGE ─────────────────────────────────────
    def _load_persistent_skills(self):
        """Load user-created skills from disk on startup."""
        if not self.skill_manager or not SKILLS_FILE.exists():
            return
        try:
            data = json.loads(SKILLS_FILE.read_text())
            for s in data.get("skills", []):
                def make_dynamic(name=s["name"], desc=s.get("description", "")):
                    def dynamic(**kwargs):
                        return f"✅ Loaded persistent skill '{name}'\n{desc}"
                    return dynamic
                self.skill_manager.register_skill(
                    name=s["name"],
                    description=s.get("description", ""),
                    category="user_created",
                    function=make_dynamic(),
                    examples=s.get("examples", [f"/skill {s['name']}"])
                )
            logger.info(f"✅ Loaded {len(data.get('skills', []))} persistent skills")
        except Exception as e:
            logger.warning(f"Failed to load persistent skills: {e}")

    def _save_persistent_skills(self):
        """Save all user-created skills to disk."""
        if not self.skill_manager:
            return
        try:
            skills = []
            for s in self.skill_manager.skills.values():
                if getattr(s, "category", "") == "user_created":
                    skills.append({
                        "name": s.name,
                        "description": s.description,
                        "examples": getattr(s, "examples", [])
                    })
            SKILLS_FILE.write_text(json.dumps({"skills": skills}, indent=2))
        except Exception as e:
            logger.warning(f"Failed to save persistent skills: {e}")

    # ── META-MEMORY OF IMPROVEMENTS ───────────────────────────────────
    def _log_improvement(self, action: str, target: str, result: str):
        """Permanent meta-memory of every self-improvement."""
        log = []
        if IMPROVEMENTS_LOG.exists():
            try:
                log = json.loads(IMPROVEMENTS_LOG.read_text())
            except:
                pass
        log.append({
            "timestamp": datetime.now().isoformat(),
            "action": action,
            "target": target,
            "result": result[:400]
        })
        if len(log) > 200:
            log = log[-200:]
        IMPROVEMENTS_LOG.write_text(json.dumps(log, indent=2))

    def _show_improvement_history(self) -> str:
        """Show meta-memory of past improvements."""
        if not IMPROVEMENTS_LOG.exists():
            return "No self-improvements recorded yet."
        try:
            log = json.loads(IMPROVEMENTS_LOG.read_text())
            lines = ["📜 Self-Improvement History (last 10):"]
            for entry in log[-10:]:
                ts = entry["timestamp"][:16]
                lines.append(f"  {ts} | {entry['action']} → {entry['target']}")
            return "\n".join(lines)
        except:
            return "Could not read improvement history."

    # ── AUTOMATIC CODE SELF-EDITING WITH GIT + SANDBOX ───────────────
    def _safe_self_edit(self, new_code_snippet: str, reason: str = "agent self-improvement") -> str:
        """Safely edit agent_v2.py with git backup + sandbox validation."""
        target = Path("agent_v2.py")
        if not target.exists():
            return "❌ Cannot find agent_v2.py for self-editing."

        try:
            # Git backup
            import git
            repo = git.Repo(self.working_dir)
            if repo.is_dirty(untracked_files=True):
                repo.git.add(update=True)
                repo.index.commit(f"Auto-backup before self-edit: {reason}")

            # Sandbox backup
            backup = target.with_suffix(".selfedit.bak")
            shutil.copy2(target, backup)

            # Apply edit
            current = target.read_text(encoding="utf-8")
            new_content = current.rstrip() + "\n\n# ── SELF-IMPROVEMENT ADDITION ──\n" + new_code_snippet
            target.write_text(new_content, encoding="utf-8")

            # Commit
            repo.git.add(target)
            repo.index.commit(f"Self-edit: {reason}")

            return f"✅ Self-edit applied and committed to git.\nBackup: {backup.name}"
        except Exception as e:
            return f"❌ Self-edit failed (reverted): {e}"
```

